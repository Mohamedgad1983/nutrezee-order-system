.env
.env.*
!.env.example

# Linked worktree of THIS repository (not an independent repo): discovery
# evidence record on branch claude-codex/step-1-discovery, pushed to origin.
# Path ignored because a worktree checkout cannot be tracked by another worktree.
nutrezee-step-1-discovery/

# macOS
.DS_Store

# Node (root stray-run protection; app/ has its own)
node_modules/

# Local agent / tooling config (never commit — may hold local perms/secrets)
.claude/
.github/skills/
skills-lock.json

# Secret material — defense in depth so credentials can never be added by accident
*.key
*.pem
*.p12
*.pfx
credentials*.json
*-service-account*.json
*.local

# Legacy extraction output — raw HTML / JSONL contain customer PII; NEVER commit.
# (The real runs write OUTSIDE the repo, but guard in case OUT points inside it.)
legacy-detail-out/
**/legacy-detail-out/
*.html.gz
**/raw/*.jsonl
**/migration-output/
