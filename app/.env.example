# Nutrezee Order System — environment template (WP-00; D2/D4 fixes 2026-06-11)
# Copy to .env (gitignored). Real values come from the host secret store —
# never commit secrets (GAP-SEC-05; 16_Deployment/environment_plan.md).

# PostgreSQL 16 — local dev default matches docker/compose.yml.
# Staging/prod: managed-PG TLS rides the URL (?sslmode=require).
DATABASE_URL=postgres://nutrezee:nutrezee@localhost:5432/nutrezee

# API
PORT=3000

# Session cookie Secure flag (D2). Unset => follows NODE_ENV (production = Secure,
# which REQUIRES TLS in front of the API — browser logins silently fail over plain
# HTTP). COOKIE_SECURE=false is an explicit escape hatch for a pre-TLS internal
# staging smoke ONLY; never run a pilot with it set.
#COOKIE_SECURE=false

# In-process outbox dispatch + audit read-queue drain (2s sweeps). Leave unset in
# every deployed environment; OUTBOX_DISPATCHER=off is for tests only.
#OUTBOX_DISPATCHER=off

# NOTE (D4): SESSION_SECRET was removed 2026-06-11 — no code ever read it.
# Sessions are server-side rows keyed by an opaque random id in the nz_session
# cookie (DEC-011: no JWTs); there is nothing to sign. If cookie signing is ever
# introduced, reintroduce the variable together with the code that consumes it.

# ----------------------------------------------------------------------------
# Daily internal "expiring subscription" email (scripts/expiring-subscription-email.mjs)
# Internal staff report to the Nutrition Doctor only — NEVER emails customers,
# never triggers WhatsApp/marketing. Disabled + dry-run by default; a real send
# requires ALL of: ENABLED=true, DRY_RUN=false, NUTRITION_DOCTOR_EMAIL set, and an
# SMTP transport configured (plus the optional `nodemailer` dependency installed).
#NUTRITION_DOCTOR_EMAIL=doctor@nutrezee.example      # required recipient; no send if unset
#EXPIRING_SUBSCRIPTION_EMAIL_ENABLED=false           # master on/off; default off
#EXPIRING_SUBSCRIPTION_DRY_RUN=true                  # render+log only; default true
#EXPIRING_SUBSCRIPTION_DAYS_AHEAD=3                  # days before expiry to report
#EXPIRING_SUBSCRIPTION_WINDOW_MODE=exact             # 'exact' (= today+N) | 'within' (today+1..today+N)
#EXPIRING_SUBSCRIPTION_TZ=Asia/Kuwait                # business date timezone (UTC+3, no DST)
# SMTP transport (optional; only used for a real send):
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=
#SMTP_SECURE=false
